# ─────────────────────────────────────────────────────────────────
# Melodia — environment config
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# Port the Node.js server listens on (default 3000)
PORT=3000

# Your TTAPI key — get one at https://ttapi.io
# You can also enter this in the browser UI instead of putting it here.
TTAPI_KEY=

# ─── Cloudflare Tunnel public URL ────────────────────────────────
#
# This MUST be set for TTAPI to be able to fetch audio files you upload.
#
# OPTION A — Named tunnel (recommended, permanent URL):
#   1. Log in:    cloudflared login
#   2. Create:    cloudflared tunnel create melodia
#   3. Route:     cloudflared tunnel route dns melodia melodia.yourdomain.com
#   4. Set below: PUBLIC_URL=https://melodia.yourdomain.com
#
# OPTION B — Quick temporary tunnel (URL changes every restart):
#   Run in a separate terminal: cloudflared tunnel --url http://localhost:3000
#   Copy the https://*.trycloudflare.com URL it prints and paste below.
#   NOTE: update this every time you restart the tunnel.
#
PUBLIC_URL=https://melodia.yourdomain.com
